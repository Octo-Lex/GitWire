{
  "name": "gitwire",
  "version": "0.12.0",
  "private": true,
  "description": "AI-powered GitHub account management platform",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "npm --workspace=@gitwire/web run dev",
    "build": "npm run --workspaces build",
    "lint": "eslint packages/*/src/",
    "test": "npm run --workspaces --if-present test",
    "test:unit": "npm run --workspaces --if-present test",
    "test:integration": "npm --workspace=@gitwire/web run test:integration",
    "test:stress": "npm --workspace=@gitwire/web run test:stress",
    "test:all": "npm --workspace=@gitwire/web run test:all",
    "db:migrate": "node scripts/migrate.js",
    "start": "npm --workspace=@gitwire/web run start",
    "prepare": "husky 2>/dev/null || true",
    "benchmark": "node scripts/benchmark.js",
    "benchmark:api": "node scripts/benchmark.js --api",
    "benchmark:webhook": "node scripts/benchmark.js --webhook"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "eslint": "^8.0.0",
    "husky": "^9.1.7",
    "jest": "^29.0.0",
    "ts-node": "^10.9.2"
  }
}
