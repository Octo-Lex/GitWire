# ── GitWire Docker Build Context ──────────────────────────────
# Exclude everything not needed for production runtime.
# This shrinks the build context and prevents dev tooling
# (husky, tests, docs) from interfering with the container build.

# Version control
.git/
.gitignore

# CI/CD
.github/

# Pre-commit hooks — not needed in container
.husky/

# Documentation site
docs/

# Security reports
security/

# Test scripts only (keep migrate.js)
scripts/secret-leak-stress-test.sh
scripts/create-test-issues.js
scripts/update-webhook.js

# Test files
*.test.*
*.spec.*
tests/
__tests__/

# Development configs
.gitleaks.toml
.editorconfig
.prettierrc*
.eslintrc*

# Brand assets and media
MediaPackage*
index2.html
index.html
*.png
*.jpg
*.svg

# IDE
.vscode/
.idea/

# OS files
Thumbs.db
.DS_Store

# Local env files (production uses env_file in docker-compose)
.env
.env.*
!.env.example

# Secrets — never bake private keys into the image
*.pem
secrets/

# Already installed via npm ci
node_modules/
