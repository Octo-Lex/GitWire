# ─── GitHub App ───────────────────────────────────────────────
# From: https://github.com/settings/apps/<your-app>
GITHUB_APP_ID=                        # e.g. 123456
GITHUB_APP_CLIENT_ID=                 # e.g. Iv1.abc123def456
GITHUB_APP_CLIENT_SECRET=             # your client secret
GITHUB_WEBHOOK_SECRET=                # random string you set in the App config
# Paste the full PEM private key (newlines as \n), or use GITHUB_PRIVATE_KEY_PATH
GITHUB_PRIVATE_KEY=                   # "-----BEGIN RSA PRIVATE KEY-----\n..."
# GITHUB_PRIVATE_KEY_PATH=./config/private-key.pem   # alternative: point to file

# ─── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ─── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql://gitops:password@localhost:5432/gitops_hub

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Claude API ───────────────────────────────────────────────
ANTHROPIC_API_KEY=                    # sk-ant-...

# ─── App settings ─────────────────────────────────────────────
# Base URL where GitHub sends webhooks (must be publicly reachable)
# Use ngrok / Cloudflare Tunnel during local dev
APP_BASE_URL=https://your-vps-domain.com

# ─── API Authentication ─────────────────────────────────────────
# Comma-separated list of API keys for REST API access.
# If unset, a random key is generated on startup and logged.
# API_KEY=your-secret-api-key-here
# API_KEYS=key-one,key-two,key-three

# ─── Executor Service (v0.23.0) ─────────────────────────────────
# The executor-service backend runs validator containers via a private API.
# The app never touches Docker authority; the executor-service container
# owns the CT-local Docker socket (mounted in docker-compose.yml).
# All values MUST be set identically in both gitwire-app and
# gitwire-executor-service environments (compose wires this automatically).

# Which executor backend to use. Default: executor-service (v0.23.0+).
# Set to 'node-executor' for dev/testing without the executor service.
GITWIRE_EXECUTOR_BACKEND=executor-service

# The executor service's private URL (compose service name).
GITWIRE_EXECUTOR_SERVICE_URL=http://gitwire-executor-service:3003

# Shared bearer token for the executor service's private API.
# Generate with: openssl rand -hex 32
# MUST be the same in both gitwire-app and gitwire-executor-service.
GITWIRE_EXECUTOR_SERVICE_TOKEN=

# Pinned validator image identity. Both ref and digest MUST be set for
# pass-capable validation. The ref must include @sha256:<hex>.
# Example: registry.example.com/gitwire/validator@sha256:abc123...
GITWIRE_VALIDATOR_IMAGE_REF=
GITWIRE_VALIDATOR_IMAGE_DIGEST=
